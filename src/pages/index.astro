---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Service from "../components/Service.astro";
import AboutLiege from "../components/AboutLiege.astro";
import ContactForm from "../components/ContactForm.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
---

<Layout title="Débouchage Liège | Bob24 - Plombier d'urgence">
	<Hero />
	<section class="cta-banner">
		<div class="cta-banner__inner">
			<h2 class="cta-banner__title">Nous sommes disponibles à Liège jour et nuit, weekends et jours fériés</h2>
			<a class="cta-banner__btn" href="tel:+32497546868">
				<span class="cta-banner__btn-icon">
					<svg aria-hidden="true" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg">
						<path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/>
					</svg>
				</span>
				<span class="cta-banner__btn-text">0497 54 68 68</span>
			</a>
		</div>
	</section>
	<Service />
	<AboutLiege />
	<ContactForm /> 
	<ServicesGrid />
</Layout>

<style>
	@import url("https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap");


	/* ─── CTA Banner Section ─── */
	.cta-banner {
		background-image: linear-gradient(81deg, #D33071 0%, #35717A 100%);
		padding: 20px 0;
		transition: background 0.3s, border 0.3s, border-radius 0.3s, box-shadow 0.3s;
		font-family: "Roboto", sans-serif;
	}

	.cta-banner__inner {
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: center;
		flex-wrap: wrap;
		gap: 20px;
		max-width: 1140px;
		margin: 0 auto;
		padding: 0 15px;
	}

	.cta-banner__title {
		color: #FFFFFF;
		font-size: 25px;
		font-weight: 500;
		line-height: 1.3;
		margin: 0 20px 0 0;
		text-align: center;
	}

	.cta-banner__btn {
		display: inline-flex;
		flex-direction: row;
		align-items: center;
		gap: 7px;
		background-color: transparent;
		font-family: "Roboto", sans-serif;
		font-size: 21px;
		font-weight: 500;
		color: #FFFFFF;
		fill: #FFFFFF;
		border: 1px solid #FFFFFF;
		border-radius: 3px;
		padding: 12px 24px;
		text-decoration: none;
		line-height: 1;
		white-space: nowrap;
		transition: all 0.3s;
		flex-shrink: 0;
		align-self: center;
	}

	.cta-banner__btn:hover {
		background-color: rgba(255, 255, 255, 0.15);
	}

	.cta-banner__btn-icon {
		display: flex;
		align-items: center;
	}

	.cta-banner__btn-icon svg {
		width: 1em;
		height: 1em;
		fill: inherit;
	}

	.cta-banner__btn-text {
		display: inline-block;
	}

	/* ─── CTA Banner: Tablet (max-width: 1024px) ─── */
	@media (max-width: 1024px) {
		.cta-banner {
			padding: 30px 0;
		}

		.cta-banner__title {
			font-size: 17px;
		}

		.cta-banner__btn {
			font-size: 16px;
		}
	}

	/* ─── CTA Banner: Mobile (max-width: 767px) ─── */
	@media (max-width: 767px) {
		.cta-banner {
			margin-top: 50px;
			padding: 30px 0;
		}

		.cta-banner__inner {
			flex-direction: column;
			text-align: center;
		}

		.cta-banner__title {
			font-size: 18px;
			margin: 0 0 10px 0;
		}

		.cta-banner__btn {
			font-size: 21px;
			width: 100%;
			justify-content: center;
		}
	}
</style>
