---
import Layout from "../layouts/Layout.astro";
import CTAStrip from "../components/CTAStrip.astro";
---

<Layout title="Contact — Bob24 Liège | Urgence ou devis ? Contactez-nous">

	<!-- Main Contact Section: 50/50 split (post-1453.css: col 2f48f13 = 50%, col 6f51ef1 = 49.665%) -->
	<section class="contact-page">
		<div class="contact-page__inner">

			<!-- Left: Info (50% with 0% 10% 0% 0% padding, per post-1453.css) -->
			<div class="contact-page__info">
				<span class="contact-page__label">Allo BOB24</span>
				<h1 class="contact-page__title">Urgence ou devis ?<br/>contactez-nous, on s'en occupe !</h1>
				<p class="contact-page__desc">Une nouvelle installation à Liège, un entretien ou un dépannage en urgence ? Laissez-nous votre message, nous vous contacterons dans les meilleurs délais.</p>

				<ul class="contact-page__details">
					<li> 
						<span class="contact-page__detail-icon">
							<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512"><path d="M215.7 499.2C267 435 384 279.4 384 192C384 86 298 0 192 0S0 86 0 192c0 87.4 117 243 168.3 307.2c12.3 15.3 35.1 15.3 47.4 0zM192 128a64 64 0 1 1 0 128 64 64 0 1 1 0-128z"/></svg>
						</span>
						<span>Rue St Léonard, 4000 Liège, Belgique</span>
					</li>
					<li>
						<span class="contact-page__detail-icon">
							<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512"><path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/></svg>
						</span>
						<a href="tel:+32497546868">0497 54 68 68</a>
					</li>
					<li>
						<span class="contact-page__detail-icon">
							<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512"><path d="M48 64C21.5 64 0 85.5 0 112c0 15.1 7.1 29.3 19.2 38.4L236.8 313.6c11.4 8.5 27 8.5 38.4 0L492.8 150.4c12.1-9.1 19.2-23.3 19.2-38.4c0-26.5-21.5-48-48-48H48zM0 176V384c0 35.3 28.7 64 64 64H448c35.3 0 64-28.7 64-64V176L294.4 339.2c-22.8 17.1-54 17.1-76.8 0L0 176z"/></svg>
						</span>
						<a href="mailto:info@bob24.be">info@bob24.be</a>
					</li>
				</ul>
			</div>

			<!-- Right: Form (~49.665%) -->
			<div class="contact-page__form">
				<div class="contact-page__form-box">
					<form class="cf-form" name="contact" method="POST" action="#">
						<div class="cf-row cf-row--half">
							<div class="cf-field">
								<label class="cf-label" for="contact-name">Nom et prénom</label>
								<input class="cf-input" id="contact-name" type="text" name="nom" placeholder="" />
							</div>
							<div class="cf-field">
								<label class="cf-label" for="contact-email">Email <span class="cf-required">*</span></label>
								<input class="cf-input" id="contact-email" type="email" name="email" required placeholder="" />
							</div>
						</div>
						<div class="cf-field">
							<label class="cf-label" for="contact-phone">Téléphone</label>
							<input class="cf-input" id="contact-phone" type="tel" name="telephone" placeholder="" />
						</div>
						<div class="cf-field">
							<label class="cf-label" for="contact-message">Message</label>
							<textarea class="cf-input cf-textarea" id="contact-message" name="message" rows="5" placeholder=""></textarea>
						</div>
						<div class="cf-actions">
							<button type="submit" class="cf-submit">Envoyer</button>
						</div>
					</form>
				</div>
			</div>

		</div>
	</section>

	<!-- Google Map (height: 590px per post-1453.css: .elementor-element-fb5ea84 .sc_googlemap) -->
	<section class="contact-map">
		<iframe
			class="contact-map__iframe"
			src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d80626.12271867218!2d5.499731!3d50.645002!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47c0f9f2c16a84ef%3A0x52ed7f4c3e6e6c99!2sLi%C3%A8ge%2C%20Belgium!5e0!3m2!1sen!2sBE!4v1648000000000"
			width="100%"
			height="590"
			allowfullscreen=""
			loading="lazy"
			referrerpolicy="no-referrer-when-downgrade"
			title="Bob24 — Rue St Léonard, Liège"
		></iframe>
	</section>

	<CTAStrip />
</Layout>

<style>
	/* ─── Main Contact Section ─── */
	.contact-page {
		padding: 100px 0 80px;
		font-family: "DM Sans", sans-serif;
	}

	.contact-page__inner {
		max-width: 1140px;
		margin: 0 auto;
		padding: 0 20px;
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 0;
	}

	/* Left col: 50% width, padding: 0% 10% 0% 0% (per post-1453.css elementor-element-2f48f13) */
	.contact-page__info {
		width: 50%;
		flex-shrink: 0;
		padding: 0 10% 0 0;
	}

	/* Right col: ~49.665% (per post-1453.css elementor-element-6f51ef1) */
	.contact-page__form {
		width: 49.665%;
		flex-shrink: 0;
	}

	/* ─── Info Column ─── */
	.contact-page__label {
		display: inline-block;
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: #35717A;
		margin-bottom: 20px;
	}

	.contact-page__title {
		font-size: 42px;
		font-weight: 700;
		color: #222626;
		line-height: 1.15;
		margin: 0 0 22px;
	}

	.contact-page__desc {
		font-size: 17px;
		color: #7A7A7A;
		line-height: 1.7;
		margin: 0 0 40px;
	}

	/* Contact details list (margin-top: 30px per elementor-element-c9c60ba) */
	.contact-page__details {
		list-style: none;
		padding: 0;
		margin: 30px 0 0 0;
		display: flex;
		flex-direction: column;
		gap: 20px;
	}

	.contact-page__details li {
		display: flex;
		align-items: center;
		gap: 16px;
		font-size: 16px;
		color: #222626;
		font-weight: 500;
	}

	.contact-page__details a {
		color: #222626;
		text-decoration: none;
		transition: color 0.3s;
		font-weight: 600;
	}

	.contact-page__details a:hover {
		color: #35717A;
	}

	.contact-page__detail-icon {
		width: 42px;
		height: 42px;
		background-color: #F2F5F5;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.contact-page__detail-icon svg {
		width: 16px;
		height: 16px;
		fill: #35717A;
	}

	/* ─── Form Box ─── */
	.contact-page__form-box {
		background: #ffffff;
		padding: 48px 44px;
		box-shadow: 0 8px 48px rgba(34, 38, 38, 0.08);
		border-radius: 4px;
	}

	.cf-form {
		display: flex;
		flex-direction: column;
	}

	.cf-row--half {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 20px;
	}

	.cf-field {
		margin-bottom: 20px;
	}

	.cf-label {
		display: block;
		font-size: 14px;
		font-weight: 500;
		color: #222626;
		margin-bottom: 8px;
	}

	.cf-required {
		color: #D33071;
	}

	.cf-input {
		width: 100%;
		border: 1px solid #e0e0e0;
		background-color: #fcfcfc;
		border-radius: 999px;
		padding: 14px 20px;
		font-family: "DM Sans", sans-serif;
		font-size: 15px;
		color: #222626;
		outline: none;
		transition: border-color 0.3s, background-color 0.3s;
		box-sizing: border-box;
	}

	.cf-textarea {
		border-radius: 16px;
		resize: none;
		min-height: 130px;
	}

	.cf-input:focus {
		border-color: #D33071;
		background-color: #ffffff;
	}

	.cf-actions {
		margin-top: 10px;
	}

	.cf-submit {
		background-color: #D33071;
		color: #ffffff;
		padding: 16px 44px;
		border-radius: 999px;
		font-family: "DM Sans", sans-serif;
		font-weight: 600;
		font-size: 16px;
		border: none;
		cursor: pointer;
		transition: background-color 0.3s;
		display: inline-block;
	}

	.cf-submit:hover {
		background-color: #b5255d;
	}

	/* ─── Map (height: 590px per post-1453.css) ─── */
	.contact-map {
		display: block;
		line-height: 0;
	}

	.contact-map__iframe {
		display: block;
		width: 100%;
		height: 590px;
		border: 0;
	}

	/* ─── Tablet: 1024px — adjust right padding (0% 12% 0% 0%) ─── */
	@media (max-width: 1024px) {
		.contact-page__info {
			padding: 0 12% 0 0;
		}
	}

	/* ─── Mobile: 767px — stack cols, remove right padding ─── */
	@media (max-width: 767px) {
		.contact-page {
			padding: 60px 0 50px;
		}

		.contact-page__inner {
			flex-direction: column;
			gap: 50px;
		}

		.contact-page__info,
		.contact-page__form {
			width: 100%;
			padding: 0;
		}

		.contact-page__title {
			font-size: 28px;
		}

		.cf-row--half {
			grid-template-columns: 1fr;
		}

		.contact-page__form-box {
			padding: 32px 24px;
		}

		.contact-map__iframe {
			height: 360px;
		}
	}
</style>