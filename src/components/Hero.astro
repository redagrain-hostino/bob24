---
---

<section class="hero">
	<div class="hero__image-col" aria-hidden="true">
		<!-- background image column -->
	</div>

	<div class="hero__content-col">
		<h1 class="hero__title">Débouchage Liège</h1>

		<div class="hero__text">
			<p>
				Besoin d'un débouchage urgent à Liège ? Contactez dès
				maintenant Bob24. Chaque intervention de débouchage <b
					>représente un véritable défi</b
				> pour nos déboucheurs.
			</p>
			<p>
				<img
					decoding="async"
					class="hero__emoji"
					role="img"
					draggable="false"
					src="https://s.w.org/images/core/emoji/16.0.1/svg/1f7e2.svg"
					alt="🟢"
				/>
				13 plombiers sont <strong>disponibles</strong> en ce moment à
				Liège.
			</p>
		</div>

		<div class="hero__cta-wrapper">
			<a class="hero__cta-btn" href="tel:+32497546868">
				<span class="hero__cta-icon">
					<svg
						aria-hidden="true"
						viewBox="0 0 448 512"
						xmlns="http://www.w3.org/2000/svg"
					>
						<path
							d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"
						></path>
					</svg>
				</span>
				<span class="hero__cta-text">0497 54 68 68</span>
			</a>
		</div>

		<div class="hero__reviews">
			<img
				fetchpriority="high"
				decoding="async"
				width="1024"
				height="229"
				src="/images/avis-plombier-liege-1024x229.png"
				alt="Avis débouchage Liège"
				srcset="/images/avis-plombier-liege-1024x229.png 1024w, /images/avis-plombier-liege-600x134.png 600w, /images/avis-plombier-liege-300x67.png 300w, /images/avis-plombier-liege-768x171.png 768w, /images/avis-plombier-liege-370x83.png 370w"
				sizes="(max-width: 1024px) 100vw, 1024px"
			/>
		</div>

		<div class="hero__stats">
			<div class="hero__stat">
				<div class="hero__stat-number">
					<span class="animated-counter" data-target="20">1</span><span class="hero__stat-suffix">+</span>
				</div>
				<div class="hero__stat-label">Plombiers dispo</div>
			</div>
			<div class="hero__stat">
				<div class="hero__stat-number">
					<span class="animated-counter" data-target="24">1</span><span class="hero__stat-suffix">H</span>
				</div>
				<div class="hero__stat-label">Jour et nuit</div>
			</div>
			<div class="hero__stat">
				<div class="hero__stat-number">
					<span class="hero__stat-prefix">+</span><span class="animated-counter" data-target="15">1</span>
				</div>
				<div class="hero__stat-label">ans d'expérience</div>
			</div>
		</div>
	</div>
</section>

<style>
	/* ─── Hero Section ─── */
	.hero {
		display: flex;
		min-height: 100vh;
		align-items: stretch;
		position: relative;
		font-family: "Roboto", sans-serif;
	}

	/* ─── Left: Image Column ─── */
	.hero__image-col {
		width: 39.393%;
		flex-shrink: 0;
		background-color: #ffe8f0;
		background-image: url("/images/plombier-liege.jpg");
		background-position: top center;
		background-repeat: no-repeat;
		background-size: cover;
		transition:
			background 0.3s,
			border 0.3s,
			border-radius 0.3s,
			box-shadow 0.3s;
	}

	/* ─── Right: Content Column ─── */
	.hero__content-col {
		width: 60.607%;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: flex-start;
		margin-left: 8%;
		margin-right: 8%;
		padding-top: 7%;
		padding-bottom: 2rem;
	}

	/* ─── Heading ─── */
	.hero__title {
		font-size: 4.3vw;
		color: #222626;
		margin: 0 0 0 0;
		padding: 0;
		line-height: 1;
	}

	/* ─── Text Block ─── */
	.hero__text {
		margin-top: 1rem;
		margin-right: 35%;
		margin-bottom: 1.5rem;
		color: #7a7a7a;
	}

	.hero__text p {
		margin-bottom: 1.5rem;
	}

	.hero__emoji {
		width: 1em;
		height: 1em;
		vertical-align: -0.1em;
	}

	/* ─── CTA Button ─── */
	.hero__cta-wrapper {
		margin-top: 1rem;
		margin-bottom: 1rem;
	}

	.hero__cta-btn {
		display: inline-flex;
		flex-direction: row;
		align-items: center;
		gap: 7px;
		background-color: transparent;
		font-family: "Roboto", sans-serif;
		font-size: 29px;
		font-weight: 500;
		color: #35717a;
		fill: #35717a;
		border: 3px solid #35717a;
		border-radius: 3px;
		padding: 12px 24px;
		text-decoration: none;
		line-height: 1;
		transition: all 0.3s;
	}

	.hero__cta-btn:hover {
		background-color: #35717a;
		color: #fff;
		fill: #fff;
	}

	.hero__cta-icon {
		display: flex;
		align-items: center;
	}

	.hero__cta-icon svg {
		width: 1em;
		height: 1em;
		fill: inherit;
	}

	.hero__cta-text {
		display: inline-block;
	}

	/* ─── Reviews Image ─── */
	.hero__reviews {
		margin-top: 0;
		margin-bottom: 0;
		text-align: left;
	}

	.hero__reviews img {
		width: 31%;
		height: auto;
		display: block;
	}

	/* ─── Stats / Counters ─── */
	.hero__stats {
		display: flex;
		flex-direction: row;
		align-items: flex-start;
		flex-wrap: wrap;
		margin-top: 1.25rem;
	}

	.hero__stat {
		margin-right: 40px;
		margin-bottom: 20px;
		padding-right: 40px;
		border-right: 1px solid #e9e9e9;
	}

	.hero__stat-number {
		color: #35717a;
		font-size: 47px;
		font-weight: 700;
		line-height: 1;
	}

	.hero__stat-prefix,
	.hero__stat-suffix {
		font-size: inherit;
		font-weight: inherit;
		color: inherit;
	}

	.hero__stat-label {
		color: #222626;
		font-size: 19px;
		line-height: 1em;
		margin-top: 0.25rem;
	}

	/* ─── Responsive: Tablet (max-width: 1024px) ─── */
	@media (max-width: 1024px) {
		.hero {
			min-height: 50vh;
		}

		.hero__image-col {
			width: 41%;
		}

		.hero__content-col {
			width: 59%;
		}

		.hero__title {
			font-size: 4.7vw;
		}

		.hero__text {
			margin-right: 0;
		}

		.hero__stat {
			margin-right: 25px;
			padding-right: 0;
			border-right: none;
		}

		.hero__stat-number {
			font-size: 40px;
		}

		.hero__stat-label {
			font-size: 18px;
		}
	}

	/* ─── Responsive: Mobile (max-width: 767px) ─── */
	@media (max-width: 767px) {
		.hero {
			flex-direction: column;
			min-height: auto;
		}

		.hero__image-col {
			width: 100%;
			min-height: 450px;
		}

		.hero__content-col {
			width: 100%;
			margin-left: 5%;
			margin-right: 5%;
			padding-top: 30px;
			padding-bottom: 30px;
		}

		.hero__title {
			font-size: 9.8vw;
		}

		.hero__text {
			margin-right: 0;
		}

		.hero__cta-btn {
			font-size: 21px;
		}

		.hero__reviews img {
			width: 71%;
		}

		.hero__stat {
			margin-right: 25px;
			padding-right: 0;
			border-right: none;
		}

		.hero__stat-number {
			font-size: 40px;
		}

		.hero__stat-label {
			font-size: 18px;
		}
	}
</style>

<script>
	// Run animation on load
	document.addEventListener('DOMContentLoaded', () => {
		const counters = document.querySelectorAll('.animated-counter');
		
		counters.forEach((counter) => {
			const el = counter as HTMLElement;
			const target = parseInt(el.getAttribute('data-target') || '0', 10);
			if (isNaN(target) || target === 0) return;
			
			const duration = 2500; // 2.5 seconds animation
			const frameDuration = 1000 / 60; // 60 frames per second
			const totalFrames = Math.round(duration / frameDuration);
			let frame = 0;
			
			// Fluid easing out formula
			const easeOutQuart = (t: number) => 1 - Math.pow(1 - t, 4);
			
			const countUp = setInterval(() => {
				frame++;
				const progress = easeOutQuart(frame / totalFrames);
				// Start from 1, animate up to target
				const currentCount = Math.round(1 + (target - 1) * progress);
				
				el.textContent = currentCount.toString();
				
				// Clear interval when done
				if (frame >= totalFrames) {
					clearInterval(countUp);
					el.textContent = target.toString();
				}
			}, frameDuration);
		});
	});
</script>
