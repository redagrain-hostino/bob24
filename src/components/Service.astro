---
export interface Props {
	subtitle?: string;
	title?: string;
	paragraphs?: string[];
	imageSrc?: string;
	imageAlt?: string;
}

const {
	subtitle = "Service débouchage Liège - 4000",
	title = "Besoin d’un débouchage immédiat à Liège ?",
	paragraphs = [
		`BOB24 Liège est votre acteur de confiance pour toute intervention urgente de <a href="/debouchage-canalisation">débouchage de canalisations</a>. Nous mettons notre expertise au service des habitants de la Cité Ardente. Nous utilisons un matériel de haute qualité (Rothembenger, Kärcher etc..) pour déboucher vos égouts dans les meilleures conditions.`,
		`Nos équipes sont actives quotidiennement à travers toute l’agglomération liégeoise, que vous soyez aux Guillemins, à Rocourt, Grivegnée, Angleur, Outremeuse ou Sclessin. Chaque intervention est réalisée avec une qualité irréprochable.`,
		`Pour un plombier sérieux et engagé à Liège, appelez le 0470 062 110 et laissez-nous nous occuper du reste.`
	],
	imageSrc = "/images/service-plombier-liege-1024x961.jpg",
	imageAlt = "Service Débouchage Liège"
} = Astro.props;
---

<section class="service">
	<div class="service__inner">
		<div class="service__content-col">
			<h2 class="service__subtitle">{subtitle}</h2>
			<h3 class="service__title">{title}</h3>

			<div class="service__text">
				{paragraphs.map((p) => (
					<p set:html={p} />
				))}
			</div>

			<div class="service__buttons">
				<a href="#" class="service__btn service__btn--primary">Appeler</a>
				<a href="tel:+32497546868" class="service__btn service__btn--secondary">
					<span class="sc_button_icon">
						<svg aria-hidden="true" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
							<path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/>
						</svg>
					</span> 
					0497 54 68 68
				</a>
			</div> 
		</div>

		<div class="service__image-col">
			<img
				decoding="async"
				width="1024"
				height="961"
				src={imageSrc}
				alt={imageAlt}
			/>
		</div>
	</div>
</section>

<style>
	@import url("https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap");

	.service {
		margin-top: 100px;
		margin-bottom: 100px;
		padding: 0;
		font-family: "Roboto", sans-serif;
	}

	.service__inner {
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		max-width: 1140px;
		margin: 0 auto;
		padding: 0 15px;
		gap: 3%;
	}

	.service__content-col {
		width: 42%;
	}

	.service__image-col {
		width: 55%;
	}

	.service__image-col img {
		width: 100%;
		height: auto;
		display: block;
	}

	/* Typography */
	.service__subtitle {
		font-family: inherit;
		font-size: 45px;
		color: #222626;
		margin-top: 0;
		margin-bottom: 10px;
		line-height: 1.2;
	}

	.service__title {
		font-family: "Roboto", sans-serif;
		font-size: 22px;
		font-weight: 500;
 		margin-top: 0;
		margin-bottom: 25px;
		line-height: 1.3;
	}

	.service__text {
		color: #7A7A7A;
		font-size: 16px;
		line-height: 1.7;
	}

	.service__text p {
		margin-bottom: 1.5rem;
	}

	.service__text :global(a) {
		color: #35717A;
		text-decoration: underline;
	}

	/* Buttons */
	.service__buttons {
		display: flex;
		flex-wrap: wrap;
		gap: 15px;
		margin-top: 30px;
		align-items: center;
	}

	.service__btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 14px 28px;
		border-radius: 3px;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.3s ease;
		line-height: 1;
	}

	.service__btn--primary {
		background-color: #35717A;
		color: #FFFFFF;
		border: 1px solid #35717A;
	}

	.service__btn--primary:hover {
		background-color: transparent;
		color: #35717A;
	}

	.service__btn--secondary {
		background-color: transparent;
		color: #222626;
		font-family: "Roboto", sans-serif;
		padding: 14px 0; /* Simple link style, less padding, based on generic 'simple' class */
	}

	.service__btn--secondary:hover {
		color: #35717A;
	}

	.sc_button_icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		margin-right: 12px;
		background-color: #F2F5F5;
		border-radius: 50%;
		width: 44px;
		height: 44px;
	}

	.sc_button_icon svg {
		width: 18px;
		height: 18px;
		fill: currentColor;
	}

	/* Responsive tweaks */
	@media (max-width: 1024px) {
		.service {
			margin-top: 70px;
			margin-bottom: 70px;
		}

		.service__inner {
			flex-direction: column;
		}

		.service__content-col,
		.service__image-col {
			width: 100%;
			padding-right: 0;
		}

		.service__content-col {
			margin-bottom: 40px;
		}

		.service__subtitle {
			font-size: 28px;
		}

		.service__title {
			font-size: 20px;
		}
	}

	@media (max-width: 767px) {
		.service {
			margin-top: 60px;
			margin-bottom: 60px;
		}

		.service__subtitle {
			font-size: 24px;
		}

		.service__title {
			font-size: 19px;
		}
		
		.service__btn {
			width: 100%;
			text-align: center;
		}
	}
</style>
