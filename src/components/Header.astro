---
// Header Component
const currentPath = Astro.url.pathname;

const navLinks = [
	{ href: "/", label: "Débouchage" },
	{ href: "/plombier-liege/", label: "Plomberie" },
	{ href: "/chauffagiste-liege/", label: "Chauffage" },
	{ href: "/jobs", label: "Jobs" },
	{ href: "/contact/", label: "Contact" },
];
---

<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,600;0,9..40,700;1,9..40,400&display=swap');

  :root {
    --header-bg:            #ffffff;
    --header-sticky-shadow: 0px 0px 28px 0px rgba(0, 0, 0, 0.1);
    --header-text:          #222626;
    --header-link:          #222626;
    --header-accent:        #13727B;
    --header-accent-hover:  #0f5b62;
    --header-logo-h:        55px;
    --header-logo-h-tablet: 45px;
    --header-logo-h-mobile: 40px;
    --header-pad-x:         55px;
  }

  .site-header {
    position: relative;
    width: 100%;
    font-family: 'DM Sans', sans-serif;
    z-index: 1000;
  }

  .header-container {
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }

  .header-logo,
  .header-nav,
  .header-cta {
    display: flex;
    align-items: center;
  } 

  .logo-image {
    display: block;
    width: auto;
    max-height: var(--header-logo-h);
    height: auto;
  }

  /* ── Navigation ── */
  .header-nav { justify-content: center; }

  .nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav-item a {
    display: block;
    padding: 10px 16px;
    color: var(--header-link);
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: capitalize;
    text-decoration: none;
    white-space: nowrap;
    position: relative;
    transition: color 0.25s ease;
  }

  .nav-item a::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 16px;
    right: 16px;
    height: 2px;
    background-color: var(--header-link);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.25s ease;
  }

  .nav-item a:hover::after,
  .nav-item.current a::after {
    transform: scaleX(1);
  }

  /* ── CTA Button ── */
  .header-cta { justify-content: flex-end; }

  .cta-button {
    display: inline-block;
    position: relative;
    overflow: hidden;
    padding: 14px 28px;
    background-color: var(--header-accent);
    color: #ffffff;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    border-radius: 3px;
    transition: background-color 0.3s ease, color 0.3s ease;
    cursor: pointer;
  }

  .cta-button::before {
    content: '';
    position: absolute;
    inset: 0;
    background-color: var(--header-accent-hover);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.35s ease;
    z-index: 0;
  }

  .cta-button:hover::before { transform: scaleX(1); }
  .cta-text { position: relative; z-index: 1; }

  /* ── Desktop Top Bar ── */
  .header-top-bar {
    display: flex;
    position: sticky;
    top: 0;
    z-index: 999;
    background-color: var(--header-bg);
    padding: 12px var(--header-pad-x);
    box-shadow: var(--header-sticky-shadow);
    box-sizing: border-box;
  }

  .header-top-bar .header-container {
    gap: 0;
    min-height: 64px;
    justify-content: space-between;
  }

  .header-top-bar .header-logo { flex: 1 1 25%; }
  .header-top-bar .header-nav  { flex: 1 1 50%; justify-content: center; }
  .header-top-bar .header-cta  { flex: 1 1 25%; justify-content: flex-end; }

  /* ── Mobile Bar ── */
  .header-mobile-bar {
    display: none;
    position: sticky;
    top: 0;
    z-index: 999;
    background-color: var(--header-bg);
    padding: 12px 20px;
    box-sizing: border-box;
    box-shadow: var(--header-sticky-shadow);
  }

  .header-mobile-bar .header-container {
    justify-content: space-between;
  }

  .menu-toggle-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--header-link);
    font-size: 26px;
    line-height: 1;
    padding: 6px;
    cursor: pointer;
    transition: color 0.25s;
  }

  .menu-toggle-btn:hover { color: var(--header-accent); }

  /* ── Mobile Sidebar Drawer ── */
  .mobile-sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1998;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .mobile-sidebar-overlay.is-open {
    display: block;
    opacity: 1;
  }

  .mobile-sidebar {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 280px;
    max-width: 85vw;
    background-color: #ffffff;
    z-index: 1999;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: -4px 0 24px rgba(0, 0, 0, 0.12);
  }

  .mobile-sidebar.is-open {
    transform: translateX(0);
  }

  .mobile-sidebar__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 24px;
    border-bottom: 1px solid #F2F5F5;
  }

  .mobile-sidebar__logo {
    max-height: 38px;
    width: auto;
  }

  .mobile-sidebar__close {
    background: none;
    border: none;
    font-size: 28px;
    line-height: 1;
    color: #222626;
    cursor: pointer;
    padding: 4px;
    transition: color 0.25s;
  }

  .mobile-sidebar__close:hover { color: #D33071; }

  .mobile-sidebar__nav {
    flex: 1;
    overflow-y: auto;
    padding: 12px 0;
  }

  .mobile-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mobile-nav-list li a {
    display: block;
    padding: 16px 28px;
    color: #222626;
    font-family: 'DM Sans', sans-serif;
    font-size: 17px;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid #F2F5F5;
    transition: color 0.2s, background-color 0.2s;
  }

  .mobile-nav-list li a:hover,
  .mobile-nav-list li.current a {
    color: #35717A;
    background-color: #F2F5F5;
  }

  .mobile-nav-list li.current a {
    border-left: 3px solid #35717A;
    padding-left: 25px;
  }

  .mobile-sidebar__cta {
    padding: 24px 28px;
    border-top: 1px solid #F2F5F5;
  }

  .mobile-sidebar__cta a {
    display: block;
    background-color: #13727B;
    color: #ffffff;
    text-align: center;
    padding: 15px 24px;
    border-radius: 3px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: background-color 0.3s;
  }

  .mobile-sidebar__cta a:hover { background-color: #0f5b62; }

  /* ── Responsive Breakpoints ── */
  @media (min-width: 768px) and (max-width: 1024px) {
    .header-mobile-bar { display: none; }
    .header-top-bar .header-logo { flex: 0 0 42%; max-width: 42%; }
    .header-top-bar .header-nav  { flex: 0 0 29%; max-width: 29%; }
    .header-top-bar .header-cta  { flex: 0 0 29%; max-width: 29%; }
    .logo-image { max-height: var(--header-logo-h-tablet); }
  }

  @media (max-width: 767px) {
    .header-top-bar    { display: none; }
    .header-mobile-bar { display: flex; }
    .header-mobile-bar .header-logo { flex: 0 0 50%; max-width: 50%; }
    .header-mobile-bar .header-mobile-toggle { flex: 0 0 50%; max-width: 50%; justify-content: flex-end; }
    .logo-image { max-height: var(--header-logo-h-mobile); }
  }

  @media (min-width: 1025px) {
    .header-top-bar    { display: flex; }
    .header-mobile-bar { display: none; }
    /* Make sure sidebar is hidden on desktop */
    .mobile-sidebar-overlay,
    .mobile-sidebar { display: none !important; }
  }
</style>

<header class="site-header">

  <!-- 1. Desktop Top Bar -->
  <div class="header-top-bar">
    <div class="header-container">

      <div class="header-logo">
        <a href="/">
          <img
            loading="lazy"
            class="logo-image"
            src="/images/cropped-logo-wh.png"
            srcset="/images/cropped-logo-wh.png 2x"
            alt="Débouchage Liège"
            width="288"
            height="116"
          />
        </a>
      </div>

      <nav class="header-nav" aria-label="Navigation principale">
        <ul class="nav-list">
          {navLinks.map(link => (
            <li class={`nav-item${currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? ' current' : ''}`}>
              <a href={link.href}><span>{link.label}</span></a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="header-cta">
        <a href="tel:+32497546868" class="cta-button">
          <span class="cta-text">Appeler : 0497 54 68 68</span>
        </a>
      </div>

    </div>
  </div>

  <!-- 2. Mobile Bar -->
  <div class="header-mobile-bar">
    <div class="header-container">

      <div class="header-logo">
        <a href="/">
          <img
            loading="lazy"
            class="logo-image"
            src="/images/cropped-logo-wh.png"
            srcset="/images/cropped-logo-wh.png 2x"
            alt="Débouchage Liège"
            width="288"
            height="116"
          />
        </a>
      </div>

      <div class="header-mobile-toggle" style="display:flex;justify-content:flex-end;flex:1;">
        <button
          class="menu-toggle-btn"
          id="mobile-menu-open"
          aria-label="Ouvrir le menu"
          aria-expanded="false"
          aria-controls="mobile-sidebar"
        >
          &#9776;
        </button>
      </div>

    </div>
  </div>

</header>

<!-- 3. Mobile Sidebar Drawer (outside header so it overlays page) -->
<div class="mobile-sidebar-overlay" id="mobile-sidebar-overlay" aria-hidden="true"></div>

<aside class="mobile-sidebar" id="mobile-sidebar" role="dialog" aria-modal="true" aria-label="Menu navigation">
  <div class="mobile-sidebar__header">
    <a href="/">
      <img src="/images/cropped-logo-wh.png" alt="Débouchage Liège" class="mobile-sidebar__logo" />
    </a>
    <button class="mobile-sidebar__close" id="mobile-menu-close" aria-label="Fermer le menu">&times;</button>
  </div>

  <nav class="mobile-sidebar__nav">
    <ul class="mobile-nav-list">
      {navLinks.map(link => (
        <li class={currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? 'current' : ''}>
          <a href={link.href}>{link.label}</a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="mobile-sidebar__cta">
    <a href="tel:+32497546868">Appeler : 0497 54 68 68</a>
  </div>
</aside>

<script>
  const openBtn = document.getElementById('mobile-menu-open');
  const closeBtn = document.getElementById('mobile-menu-close');
  const overlay = document.getElementById('mobile-sidebar-overlay');
  const sidebar = document.getElementById('mobile-sidebar');

  function openMenu() {
    sidebar?.classList.add('is-open');
    overlay?.classList.add('is-open');
    openBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    sidebar?.classList.remove('is-open');
    overlay?.classList.remove('is-open');
    openBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', closeMenu);

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>