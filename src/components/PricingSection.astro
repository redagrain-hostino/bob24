	}
	

	.icon-call-svg {
		width: 20px;
		height: 20px;
		fill: #35717A;
		transition: fill 0.3s;
	}

	.btn-call-text {
		font-weight: 700;
		font-size: 18px;
	}

	@media (max-width: 767px) {
		.pricing-section {
			margin-top: 60px;
			margin-bottom: 60px;
		}

		.pricing-section__title {
			font-size: 32px;
		}

		.pricing-section__content {
			font-size: 16px;
		}

		.pricing-section__content h3 {
			font-size: 24px;
			margin-top: 40px;
		}

		.pricing-section__actions {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
