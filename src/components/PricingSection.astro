	}

	.pricing-section__list li::before {
		content: '✓';
		position: absolute;
		left: 0;
		top: 0;
		color: #35717A;
		font-weight: 900;
		font-size: 18px;
	}

	.pricing-section__actions {
		display: flex;
		align-items: center;
		gap: 25px;
		flex-wrap: wrap;
		padding-top: 20px;
		border-top: 2px solid #F2F5F5;
	}

	.pricing-section__btn-primary {
		background-color: #35717A;
		color: #FFFFFF;
		padding: 16px 36px;
		font-weight: 600;
