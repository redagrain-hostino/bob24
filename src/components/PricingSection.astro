	}

	.pricing-section__list {
		list-style: none;
		padding-left: 0;
		margin-top: 20px;
		margin-bottom: 30px;
	}

	.pricing-section__list li {
		position: relative;
		padding-left: 35px;
		margin-bottom: 15px;
		color: #222626; /* Darker list items for contrast */
