	}

	.pricing-section__inner {
		max-width: 1140px;
		margin: 0 auto;
		padding: 0 15px;
	}

	.pricing-section__title {
		font-size: 38px;
		font-weight: 700;
		color: #222626;
		margin-top: 0;
		margin-bottom: 30px;
		line-height: 1.2;
	}

	.pricing-section__content {
		color: #7A7A7A;
		font-size: 18px;
		line-height: 1.8;
		margin-bottom: 40px;
	}

	.pricing-section__content p {
		margin-bottom: 20px;
	}

	.pricing-section__image {
		width: 100%;
		height: auto;
		margin-bottom: 40px;
		margin-top: 15px;
		box-shadow: 0 5px 20px rgba(0,0,0,0.05);
	}

	.pricing-section__content h3 {
