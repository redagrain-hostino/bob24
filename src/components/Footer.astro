---

---

<footer class="footer">
	<div class="footer__inner">
		<div class="footer__top">
			<!-- Col 1: Brand/Slogan -->
			<div class="footer__col footer__col--brand">
				<h2 class="footer__title">
					Plomberie, Chauffage et Débouchage à Liège
				</h2>
			</div>

			<!-- Col 2: Address & Social -->
			<div class="footer__col footer__col--address">
				<h6 class="footer__subtitle">Adresse</h6>
				<p class="footer__text">Rue St Léonard, 4000 Liège, Belgique</p>
				<div class="footer__socials">
					<a
						target="_blank"
						rel="nofollow"
						href="https://www.facebook.com/bob24be"
						aria-label="Facebook Bob24"
						class="footer__social-link"
					>
						<svg
							viewBox="0 0 320 512"
							aria-hidden="true"
							xmlns="http://www.w3.org/2000/svg"
						>
							<path
								d="M279.14 288l14.22-92.66h-88.91v-60.13c0-25.35 12.42-50.06 52.24-50.06h40.42V6.26S260.43 0 225.36 0c-73.22 0-121.08 44.38-121.08 124.72v70.62H22.89V288h81.39v224h100.17V288z"
							></path>
						</svg>
					</a>
				</div>
			</div>

			<!-- Col 3: Contact -->
			<div class="footer__col footer__col--contact">
				<h6 class="footer__subtitle">Allo Bob24</h6>
				<a class="footer__link" href="mailto:info@bob24.be"
					>info@bob24.be</a
				>
				<a
					class="footer__link footer__link--phone"
					href="tel:+32497546868">0497 54 68 68</a
				>
			</div>
		</div>

		<!-- Footer Bottom Divider and Copyright -->
		<div class="footer__bottom">
			<p class="footer__copyright">
				Bob24.be © {new Date().getFullYear()}. All Rights Reserved.
			</p>
		</div>
	</div>
</footer>

<style>
	.footer {
		background-color: #161a1a;
		padding: 80px 0 30px 0;
		color: #ffffff;
		font-family: "DM Sans", sans-serif;
	}

	.footer__inner {
		max-width: 1140px;
		margin: 0 auto;
		padding: 0 15px;
	}

	.footer__top {
		display: flex;
		flex-wrap: wrap;
		gap: 30px;
		justify-content: space-between;
		margin-bottom: 50px;
	}

	.footer__col {
		flex: 1;
		min-width: 200px;
	}

	.footer__col--brand {
		flex: 2; /* Mimics the 52% width mapping on desktop */
		min-width: 300px;
	}

	.footer__title {
		font-size: 34px;
		font-weight: 700;
		color: #ffffff;
		margin: 0 0 20px 0;
		line-height: 1.2;
		letter-spacing: -1px; /* Tighter letter-spacing as per title preferences */
		padding-right: 50px;
	}

	.footer__subtitle {
		font-size: 18px;
		font-weight: 700;
		color: #ffffff;
		margin: 0 0 15px 0;
	}

	.footer__text {
		color: #9c9c9c;
		font-size: 16px;
		line-height: 1.6;
		margin: 0 0 20px 0;
	}

	.footer__socials {
		display: flex;
		gap: 15px;
	}

	.footer__social-link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		background-color: #2a2e2e;
		border-radius: 50%;
		color: #ffffff;
		transition: all 0.3s ease;
	}

	.footer__social-link svg {
		width: 16px;
		height: 16px;
		fill: currentColor;
	}

	.footer__link {
		display: block;
		color: #9c9c9c;
		font-size: 16px;
		text-decoration: none;
		margin-bottom: 12px;
		transition: color 0.3s;
	}

	.footer__link--phone {
		font-size: 20px;
		font-weight: 700;
		color: #ffffff;
		margin-top: 15px;
	}

	.footer__bottom {
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		padding-top: 30px;
		display: flex;
		justify-content: flex-end; /* Elementor had empty left col and right aligned text */
	}

	.footer__copyright {
		color: #7a7a7a;
		font-size: 15px;
		margin: 0;
		font-weight: 300;
	}

	@media (max-width: 991px) {
		.footer__title {
			padding-right: 0;
			font-size: 28px;
		}
	}

	@media (max-width: 767px) {
		.footer {
			padding: 60px 0 30px 0;
		}

		.footer__top {
			flex-direction: column;
			gap: 40px;
		}

		.footer__col {
			margin-bottom: 0px;
		}

		.footer__bottom {
			justify-content: center;
			text-align: center;
		}
	}
</style>
