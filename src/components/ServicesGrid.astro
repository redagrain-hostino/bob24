---
export interface Props {
	title?: string;
	services?: {
		title: string;
		description: string;
		link: string | null;
	}[];
}

const {
	title = "Nos services Débouchage Liège",
	services = [
		{
			title: "Débouchage de canalisation",
			description: "Intervention rapide pour déboucher vos canalisations, avec un diagnostic précis et des solutions durables proposées par Bob24 à Liège.",
			link: "/debouchage-canalisation/"
		},
		{
			title: "Débouchage des égouts",
			description: "Solution fiable pour déboucher vos égouts, grâce à une intervention rapide et soignée réalisée par l'équipe Bob24 à Liège.",
			link: "/debouchage-egout/"
		},
		{
			title: "Inspection avec caméra",
			description: "Inspection précise de vos canalisations grâce à une caméra professionnelle pour localiser rapidement tout problème.",
			link: "/inspection-avec-camera"
		},
		{
			title: "Curage canalisation",
			description: "Curage complet de vos canalisations pour éliminer résidus, graisses et dépôts, et restaurer un écoulement optimal.",
			link: "/curage-canalisation"
		},
		{
			title: "Vidange de fosse septique",
			description: "Vidange Pro de votre fosse septique, avec intervention rapide et gestion propre des déchets pour assurer le bon fonctionnement de votre installation.",
			link: "/vidange-fosse-septique"
		},
		{
			title: "Réparation des égouts",
			description: "Réparation durable de vos égouts, avec une intervention rapide pour identifier, sécuriser et remettre en état votre réseau d’évacuation.",
			link: "/reparation-des-egouts"
		}
	]
} = Astro.props;
---

<section class="services-grid">
	<div class="services-grid__inner">
		<div class="services-grid__header">
			<h2 class="services-grid__main-title">{title}</h2>
		</div>

		<div class="services-grid__columns">
			{services.map(service => (
				<div class="services-grid__item">
					<h3 class="services-grid__title">{service.title}</h3>
					<div class="services-grid__text">
						<p>{service.description}</p>
					</div>
					{service.link ? <a href={service.link} class="services-grid__btn">Lire la suite</a> : null}
				</div>
			))}
		</div>
	</div>
</section> 
<style>
	.services-grid {
		margin-top: 30px;
		margin-bottom: 50px;
		font-family: "DM Sans", sans-serif;
	}

	.services-grid__inner {
		max-width: 1140px;
		margin: 0 auto;
		padding: 0 15px;
	}

	.services-grid__main-title {
		font-family: "DM Sans", sans-serif;
		font-size: 45px;
		color: #222626;
		margin-top: 0;
		margin-bottom: 20px;
		font-weight: 700;
	}

	.services-grid__columns {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 30px;
		margin-top: 20px;
	}

	.services-grid__item {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		padding-right: 15%;
	}

	.services-grid__title {
		font-family: "DM Sans", sans-serif;
		font-size: 30px;
		font-weight: 700;
		color: #222626;
		margin-top: 0;
		margin-bottom: 10px;
		line-height: 1.2;
	}

	.services-grid__text {
		color: #7A7A7A;
		font-size: 16px;
		line-height: 1.7;
		margin-bottom: 15px;
		padding: 10px 0;
	}

	.services-grid__btn {
		background-color: #35717A;
		color: #FFFFFF;
		padding: 14px 28px;
		border-radius: 3px;
		font-family: "DM Sans", sans-serif;
		font-weight: 600;
		font-size: 15px;
		text-decoration: none;
		display: inline-block;
		transition: all 0.3s;
		border: 1px solid #35717A;
	}

	.services-grid__btn:hover {
		background-color: transparent;
		color: #35717A;
	}

	/* Responsive */
	@media (max-width: 1024px) {
		.services-grid__columns {
			grid-template-columns: repeat(2, 1fr);
			gap: 30px;
		}
		.services-grid__item {
			padding-right: 0;
		}
	}

	@media (max-width: 767px) {
		.services-grid {
			margin-top: 10px;
			margin-bottom: 30px;
		}
		.services-grid__columns {
			grid-template-columns: 1fr;
		}
		.services-grid__main-title {
			font-size: 28px;
		}
		.services-grid__title {
			font-size: 24px;
		}
	}
</style>
